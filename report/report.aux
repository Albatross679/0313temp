\@writefile{toc}{\contentsline {paragraph}{Query EM correction.}{6}{table.11}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces Training curves for two best fine-tuned models. \textbf  {Left:} T5-small ``Restricted v3'' (full fine-tune, LR\,=\,3e-4, batch\,=\,64, schema augmentation, dropout\,=\,0.1, 79 epochs; see \autoref {tab:results_t5_small}). \textbf  {Right:} T5-base ``Base sweep best'' (full fine-tune, LR\,=\,6.19e-5, batch\,=\,32, schema augmentation, dropout\,=\,0.05, label smoothing\,=\,0.15, 79 epochs; see \autoref {tab:results_t5_base}). Gray: training loss (left axis). Orange dashes: validation loss (left axis). Blue/red circles: Record F1 on a dev subset (right axis). Purple triangles (T5-base only): SQL Exact Match on a dev subset (right axis). Diamonds: final full dev set metrics. Both models converge within their time budgets, with T5-base achieving higher F1 (85.96\% vs.\ 79.60\%).}}{7}{figure.1}\protected@file@percent }
\newlabel{fig:training_curves}{{1}{7}{Training curves for two best fine-tuned models. \textbf {Left:} T5-small ``Restricted v3'' (full fine-tune, LR\,=\,3e-4, batch\,=\,64, schema augmentation, dropout\,=\,0.1, 79 epochs; see \autoref {tab:results_t5_small}). \textbf {Right:} T5-base ``Base sweep best'' (full fine-tune, LR\,=\,6.19e-5, batch\,=\,32, schema augmentation, dropout\,=\,0.05, label smoothing\,=\,0.15, 79 epochs; see \autoref {tab:results_t5_base}). Gray: training loss (left axis). Orange dashes: validation loss (left axis). Blue/red circles: Record F1 on a dev subset (right axis). Purple triangles (T5-base only): SQL Exact Match on a dev subset (right axis). Diamonds: final full dev set metrics. Both models converge within their time budgets, with T5-base achieving higher F1 (85.96\% vs.\ 79.60\%)}{figure.1}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Record F1 on the dev set across all T5-small variants. Full fine-tuning with schema augmentation (Restricted v3) achieves the highest F1 (79.6\%). LoRA with warm-start initialization (73.4\%) approaches full fine-tuning performance. MLP projection heads underperform at 8.7\%.}}{8}{figure.2}\protected@file@percent }
\newlabel{fig:dev_f1_comparison}{{2}{8}{Record F1 on the dev set across all T5-small variants. Full fine-tuning with schema augmentation (Restricted v3) achieves the highest F1 (79.6\%). LoRA with warm-start initialization (73.4\%) approaches full fine-tuning performance. MLP projection heads underperform at 8.7\%}{figure.2}{}}
