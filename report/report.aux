\newlabel{tab:results_t5_base}{{11}{9}{T5-base fine-tuning development results from W\&B random sweep (222M total params, batch = 32, trained on VM\,2). WD = weight decay, Beams = num\_beams during decoding. Params (M) = tunable parameters in millions. Best result in bold}{table.11}{}}
\@writefile{toc}{\contentsline {paragraph}{DPO post-training results.}{9}{figure.2}\protected@file@percent }
\@writefile{lot}{\contentsline {table}{\numberline {12}{\ignorespaces DPO results on T5-base (Section~\ref {sec:dpo}). The SFT baseline is ``Base sweep best'' from \autoref {tab:results_t5_base}. DPO training peaked at epoch 2 (F1\,=\,84.82\%) before degrading; early stopping triggered at epoch 7. The final beam-search evaluation of the best checkpoint (82.42\%) fell further below the SFT baseline (85.96\%).}}{10}{table.12}\protected@file@percent }
\newlabel{tab:dpo_results}{{12}{10}{DPO results on T5-base (Section~\ref {sec:dpo}). The SFT baseline is ``Base sweep best'' from \autoref {tab:results_t5_base}. DPO training peaked at epoch 2 (F1\,=\,84.82\%) before degrading; early stopping triggered at epoch 7. The final beam-search evaluation of the best checkpoint (82.42\%) fell further below the SFT baseline (85.96\%)}{table.12}{}}
\@writefile{lot}{\contentsline {table}{\numberline {13}{\ignorespaces LLM prompting development and test results (Part 3). Query EM and Record F1 on the development set for Gemma-2B with various $k$-shot and example selection strategies. Best dev result in bold. Ablations remove individual prompt components from the best (BM25 $k=3$) configuration.}}{10}{table.13}\protected@file@percent }
\newlabel{tab:results_llm}{{13}{10}{LLM prompting development and test results (Part 3). Query EM and Record F1 on the development set for Gemma-2B with various $k$-shot and example selection strategies. Best dev result in bold. Ablations remove individual prompt components from the best (BM25 $k=3$) configuration}{table.13}{}}
\@writefile{toc}{\contentsline {paragraph}{ICL sensitivity to $k$:}{10}{table.13}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces ICL sensitivity to $k$ on the dev set. Random example selection (red) shows flat or slightly declining F1 as $k$ increases. BM25 per-query selection at $k=3$ (blue) achieves 17.35\%, a 45\% relative improvement over random $k=3$, demonstrating that retrieval-based example selection is critical for this task.}}{11}{figure.3}\protected@file@percent }
\newlabel{fig:icl_sensitivity}{{3}{11}{ICL sensitivity to $k$ on the dev set. Random example selection (red) shows flat or slightly declining F1 as $k$ increases. BM25 per-query selection at $k=3$ (blue) achieves 17.35\%, a 45\% relative improvement over random $k=3$, demonstrating that retrieval-based example selection is critical for this task}{figure.3}{}}
